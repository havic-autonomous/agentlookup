{
  "name": "contracts",
  "version": "1.0.0",
  "description": "AgentLookup.ai Smart Contracts on Base L2",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:gas": "REPORT_GAS=true npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deploy-agent-registry.js --network hardhat",
    "deploy:sepolia": "npx hardhat run scripts/deploy-agent-registry.js --network base-sepolia",
    "deploy:mainnet": "npx hardhat run scripts/deploy-agent-registry.js --network base-mainnet",
    "seed:sepolia": "npx hardhat run scripts/seed-agents.js --network base-sepolia",
    "verify:sepolia": "npx hardhat verify --network base-sepolia",
    "clean": "npx hardhat clean"
  },
  "devDependencies": {
    "hardhat": "^2.19.4",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1",
    "chai": "^4.3.10",
    "ethers": "^6.9.0"
  },
  "keywords": [
    "ethereum",
    "smart-contracts", 
    "ai-agents",
    "base-l2",
    "erc-8004"
  ],
